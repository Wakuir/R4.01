<!DOCTYPE html>
<html lang="fr">
<div class="col-md-2" style="padding: 10px;">
    <div class="card">
        <div class="card-header text-center">
            <h5>
                <i class="fas fa-star"></i>
                Top Ventes
                <i class="fas fa-star"></i>
            </h5>
        </div>
        <div class="card-body text-muted text-center">
            <ul class="list-group">
                {% for article in articles %}
                    <a href="{# TODO #}">
                        <a href="/info/R401/fr/boutique/rayon/2">
                            <li class="list-group-item text-center clickable top-produit">
                                <img src="{{ asset(article.visuel) }}" style="height: 40px;">
                                <p class="top-produit">{{ article.libelle }}<br><i>{{ article.total }}vente(s)</i>
                                </p>
                            </li>
                        </a>
                    </a>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
