{% extends 'base.html.twig' %}

{% block title %}Ma Commande{% endblock %}

{% block body %}
    <div class="card col-md-12">
        <div class="card-header">
            <a class="btn-back text-secondary" href="{{ path("app_boutique_index") }}">
                <i class="fas fa-2x fa-arrow-circle-left"></i>
            </a>
            <h3>
                <i class="fas fa-shopping-cart"></i>
                Ma Commande
            </h3>
        </div>

        <div class="card col-md-12">
            <div class="card-header">
                <a class="btn-back text-secondary" href="/info/R401/fr/usager/commandes">
                    <i class="fas fa-2x fa-arrow-circle-left"></i>
                </a>
                <h3>
                    Ma commande
                    <span class="badge badge-pill badge-info">{{ numCommande }}</span>
                    du
                    {{ date | date("Y-m-d") }}
                    <br>
                </h3>
            </div>
            <div class="card-body row">
                <table class="table table-striped table-sm table-hover fit">
                    <thead>
                    <tr>
                        <th></th>
                        <th>Produit</th>
                        <th class="text-right">Prix</th>
                        <th>Quantité</th>
                        <th class="text-right">Total</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in articles %}
                        {% set produit = item.getProduit() %}
                        {% set quantite = item.getQuantite() %}
                        <tr>
                            <td>
                                <img src="{{ asset(produit.getVisuel()) }}" class="cart-img-produit" alt="{{ produit.getLibelle() }}">
                            </td>
                            <td>
                                <a href="/info/R401/fr/boutique/rayon/1">
                                    <b>{{ produit.getLibelle() }}</b>
                                </a>
                            </td>
                            <td class="text-right">
                                {{ produit.getPrix() }}&nbsp;€
                            </td>
                            <td>
                                {{ quantite }}
                            </td>
                            <td class="text-right">
                                {{ item.getPrix() }}&nbsp;€
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                    <tr>
                        <th class="text-right" colspan="4">
                            Total
                        </th>
                        <th class="text-right">
                            {{ total }}&nbsp;€
                        </th>
                    </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
