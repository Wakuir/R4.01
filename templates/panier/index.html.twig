{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
    <div class="card col-md-12">
        <div class="card-header">
            <a class="btn-back text-secondary" href="{{ path("app_boutique_index") }}">
                <i class="fas fa-2x fa-arrow-circle-left"></i>
            </a>
            <h3>
                <i class="fas fa-shopping-cart"></i>
                <span class="badge badge-pill badge-info">{{ panier | length }}</span>
                {{ "Produits - " }}
                {{ "Montant : " }}
                {{ montant | number_format(2, ",", " ") }}
            </h3>
            <div class="col-md-6 align-self-center btn-group btn-group" role="group">
                {% if is_granted('ROLE_CLIENT') and panier | length > 0 %}
                <a class="btn btn-primary" href="{{ path("app_panier_commander") }}">
                    Passer la commande
                </a>
                {% endif %}
            </div>

        </div>

        <div class="card-body">
            <table class="table table-striped table-sm table-hover">
                <thead>
                <tr>
                    <th></th>
                    <th>Produit</th>
                    <th class="text-right">Prix</th>
                    <th>Quantité</th>
                    <th class="text-right">Total</th>
                    <th>Supprimer</th>
                </tr>
                </thead>
                <tbody>
                {% for item in panier %}
                    <tr>
                        <td>
                            <img src="{{ asset(item.produit.visuel) }}" class="cart-img-produit"
                                 alt="{{ item.produit.libelle }}">
                        </td>
                        <td>
                            <a href="{{ path("app_boutique_rayon", {idCategorie: item.produit.getCategorie().getId()}) }}">
                                <b>{{ item.produit.libelle }}</b>
                            </a>
                        </td>
                        <td class="text-right">
                            {{ item.produit.prix | number_format(2, ",", " ") }}&nbsp;€
                        </td>
                        <td>
                            <a href="{{ path("app_panier_enlever", {idProduit: item.produit.id, quantite: 1}) }}">
                                <i class="fas fa-minus-square text-muted"></i>
                            </a>
                            {{ item.quantite }}
                            <a href="{{ path("app_panier_ajouter", {idProduit: item.produit.id, quantite: 1}) }}">
                                <i class="fas fa-plus-square text-muted"></i>
                            </a>
                        </td>
                        <td class="text-right">
                            {% set total = item.produit.prix * item.quantite %}
                            {{ total | number_format(2, ",", " ") }}&nbsp;€
                        </td>
                        <td>
                            <a href="{{ path("app_panier_supprimer", {idProduit : item.produit.id}) }}">
                                <i class="fas fa-trash text-muted" data-toggle="tooltip" title="" data-placement="right"
                                   data-html="true"
                                   data-original-title="Supprimer &lt;b&gt;{{ item.produit.libelle }}&lt;/b&gt;"></i>
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                <tr>
                    <th class="text-right" colspan="4">
                        Total
                    </th>
                    <th class="text-right">
                        {{ montant | number_format(2, ",", " ") }}&nbsp;€
                    </th>
                    <th>
                        <a href="{{ path("app_panier_vider") }}">
                            <i class="fas fa-trash text-muted" data-toggle="tooltip" title="" data-placement="right"
                               data-html="true" data-original-title="Vider tout le Panier"></i>
                        </a>
                    </th>
                </tr>
                </tfoot>
            </table>
        </div>
    </div>
{% endblock %}
